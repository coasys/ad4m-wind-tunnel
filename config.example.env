# Device A (creates neighbourhoods)
DEVICE_A_HOST=YOUR_DEVICE_IP         # IP or hostname
DEVICE_A_USER=your-user                # SSH user
DEVICE_A_PORT=12000               # AD4M executor port
DEVICE_A_ADMIN=test123            # Admin credential

# Device B (joins neighbourhoods)
DEVICE_B_HOST=192.168.1.199
DEVICE_B_USER=field
DEVICE_B_PORT=12000
DEVICE_B_ADMIN=test123

# Executor binary path (same on both machines)
EXECUTOR_BIN=~/workspaces/coasys/ad4m/target/release/ad4m-executor
EXECUTOR_DATA_DIR=~/ad4m-test-data

# Infrastructure (optional — set per protocol)
NOSTR_RELAY_URL=ws://YOUR_DEVICE_IP:7777
MATRIX_HOMESERVER=http://YOUR_DEVICE_IP:6167
SOLID_POD_URL=http://YOUR_DEVICE_IP:3000
ATPROTO_PDS_URL=http://YOUR_DEVICE_IP:2583
IPFS_API_A=http://YOUR_DEVICE_IP:5001
IPFS_API_B=http://192.168.1.199:5001

# Test options
SYNC_WAIT_SECONDS=10              # How long to wait for sync
LANGUAGES_TO_TEST=all             # Comma-separated or "all"

# Language addresses (set these to the actual language hashes from AD4M)
LANG_HOLOCHAIN=
LANG_ACTIVITYPUB=
LANG_ATPROTO=
LANG_NOSTR=
LANG_MATRIX=
LANG_SOLID=
LANG_IPFS=
LANG_HYPERCORE=
LANG_GIT=
